// =============================================================================
// NythosCyberAquarium.rc  -  Settings dialog + version info
// =============================================================================
#include <windows.h>
#include <commctrl.h>
#include "resource.h"

LANGUAGE LANG_ENGLISH, SUBLANG_ENGLISH_US

IDD_SETTINGS DIALOGEX 0, 0, 280, 300
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Nythos Cyber Aquarium  -  Settings"
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    GROUPBOX        "Ecosystem", -1, 8, 6, 264, 70
    LTEXT           "Fish count:", -1, 18, 22, 60, 10
    EDITTEXT        IDC_FISHCOUNT, 84, 20, 40, 13, ES_NUMBER | WS_BORDER | WS_TABSTOP
    LTEXT           "Bubble density", IDC_BUBBLE_L, 18, 42, 60, 10
    CONTROL         "", IDC_BUBBLE, "msctls_trackbar32", TBS_HORZ | WS_TABSTOP, 84, 38, 150, 18
    AUTOCHECKBOX    "Enable threat creatures (malware fish, ransomware shark)", IDC_THREAT, 18, 60, 246, 11

    GROUPBOX        "Presentation", -1, 8, 80, 264, 108
    LTEXT           "Quality:", -1, 18, 96, 60, 10
    COMBOBOX        IDC_QUALITY, 84, 94, 110, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Theme:", -1, 18, 114, 60, 10
    COMBOBOX        IDC_THEME, 84, 112, 110, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Lighting", IDC_LIGHT_L, 18, 134, 60, 10
    CONTROL         "", IDC_LIGHT, "msctls_trackbar32", TBS_HORZ | WS_TABSTOP, 84, 130, 150, 18
    AUTOCHECKBOX    "Show cyber HUD dashboard", IDC_HUD, 18, 152, 240, 11
    AUTOCHECKBOX    "Show educational cybersecurity tips", IDC_TIPS, 18, 168, 240, 11

    GROUPBOX        "AI Tips (local Ollama)", -1, 8, 192, 264, 54
    AUTOCHECKBOX    "Generate fresh tips with local Ollama", IDC_OLLAMA, 18, 206, 240, 11
    LTEXT           "Model:", -1, 18, 224, 30, 10
    EDITTEXT        IDC_MODEL, 52, 222, 150, 13, ES_AUTOHSCROLL | WS_BORDER | WS_TABSTOP

    GROUPBOX        "Audio", -1, 8, 250, 264, 28
    AUTOCHECKBOX    "Ambient ocean music (roadmap)", IDC_MUSIC, 18, 262, 200, 11

    DEFPUSHBUTTON   "OK", IDOK, 162, 282, 50, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 218, 282, 50, 14
END

#ifdef IDI_APPICON
// (icon optional; omitted to keep the build asset-free)
#endif

VS_VERSION_INFO VERSIONINFO
 FILEVERSION 1,0,0,0
 PRODUCTVERSION 1,0,0,0
 FILEOS VOS_NT_WINDOWS32
 FILETYPE VFT_APP
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "Nythos"
            VALUE "FileDescription",  "Nythos Cyber Aquarium Screensaver"
            VALUE "FileVersion",      "1.0.0.0"
            VALUE "ProductName",      "Nythos Cyber Aquarium"
            VALUE "ProductVersion",   "1.0.0.0"
            VALUE "OriginalFilename", "NythosCyberAquarium.scr"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
